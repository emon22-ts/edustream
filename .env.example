# EduStream+ environment configuration
# Copy this file to .env for local development
# In production, prefer Key Vault references via Managed Identity

# --- Azure data services ---
COSMOS_CONNECTION_STRING=AccountEndpoint=https://YOUR-COSMOS.documents.azure.com:443/;AccountKey=YOUR_KEY==;
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_STORAGE;AccountKey=YOUR_KEY==;EndpointSuffix=core.windows.net

# --- Key Vault (production) ---
# When set, secrets are loaded from Key Vault using Managed Identity
# Leave empty for local development
KEY_VAULT_URL=

# --- Authentication (Microsoft Entra ID) ---
AUTH_ENABLED=false
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# --- Content moderation (Azure AI Content Safety) ---
CONTENT_MODERATOR_ENDPOINT=
CONTENT_MODERATOR_KEY=

# --- CDN ---
# Set this to your CDN endpoint URL once configured
CDN_ENDPOINT=

# --- Application Insights (auto-injected by Azure App Service when enabled) ---
APPLICATIONINSIGHTS_CONNECTION_STRING=

# --- Server ---
PORT=3000
NODE_ENV=development
